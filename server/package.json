{
  "name": "certready-server",
  "version": "1.0.0",
  "type": "module",
  "description": "CertReady backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "seed": "node seed.js",
    "seed:course": "node scripts/upsertCourse.js",
    "seed:practice": "node scripts/seedPracticeQuestions.js",
    "seed:practice:replace": "node scripts/seedPracticeQuestionsReplace.js",
    "simulate-purchase": "node scripts/manualPurchase.js",
