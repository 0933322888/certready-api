    "rag:welder:embed": "node scripts/rag/welder/embedCorpus.js",
    "rag:welder:generate": "node scripts/rag/welder/generateAssets.js",
    "rag:welder:generate-until-done": "node scripts/rag/welder/runGenerateUntilDone.js",
