  "dependencies": {
    "@google/genai": "^1.46.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^6.9.7",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "stripe": "^14.9.0"
